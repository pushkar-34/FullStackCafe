<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canteen Automation System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-mug-hot me-2"></i>Canteen Café</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link active" href="/">Home</a></li>
                    <% if (user) { %>
                        <% if (role === 'admin') { %>
                            <li class="nav-item"><a class="nav-link" href="/admin">Admin Panel</a></li>
                        <% } else { %>
                            <li class="nav-item"><a class="nav-link" href="/student/dashboard">My Orders</a></li>
                        <% } %>
                    <% } %>
                </ul>
                <ul class="navbar-nav ms-auto align-items-center">
                    <% if (user) { %>
                        <li class="nav-item me-3">
                            <div class="d-flex align-items-center bg-white bg-opacity-10 rounded-pill px-3 py-1 border border-secondary">
                                <img src="<%= userProfilePic %>" alt="Profile" class="rounded-circle border border-2 border-white" style="width: 30px; height: 30px; object-fit: cover;">
                                <span class="text-white ms-2 small fw-bold"><%= userName %></span>
                            </div>
                        </li>
                        <li class="nav-item"><a class="nav-link text-danger" href="/logout" onclick="return confirm('Are you sure you want to logout?');">Logout</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/register">Register</a></li>
                    <% } %>
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/cart">
                            <i class="fas fa-shopping-cart"></i>
                            <% if (cart && cart.length > 0) { %>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    <%= cart.length %>
                                </span>
                            <% } %>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <header class="bg-primary text-white text-center py-5 hero-section">
        <div class="container">
            <h1 class="display-4 fw-bold">Fresh Food, Fast Service</h1>
            <p class="lead mb-4">Order your favorite meals online and skip the queue!</p>
            
            <!-- Search Bar -->
            <div class="row justify-content-center mt-4">
                <div class="col-md-6">
                    <form action="/" method="GET" class="input-group shadow">
                        <input type="text" name="search" id="searchInput" class="form-control form-control-lg" 
                               placeholder="Search for food..." autocomplete="off" 
                               value="<%= typeof currentSearch !== 'undefined' ? currentSearch : '' %>" list="searchSuggestions">
                        <datalist id="searchSuggestions"></datalist>
                        <input type="hidden" name="category" value="<%= currentCategory %>">
                        <button class="btn btn-dark btn-lg" type="submit"><i class="fas fa-search"></i></button>
                    </form>
                </div>
            </div>

            <% if (!user) { %>
                <a href="/register" class="btn btn-light btn-lg px-4 me-2">Get Started</a>
            <% } %>
        </div>
    </header>

    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center mb-5 fw-bold text-primary" style="letter-spacing: 1px;">Our Menu</h2>
            <% if (allCategories) { %>
                <div class="text-center mb-5">
                    <a href="/?category=all&search=<%= encodeURIComponent(currentSearch || '') %>" class="btn <%= !currentCategory || currentCategory === 'all' ? 'btn-primary' : 'btn-outline-primary' %>">All</a>
                    <% allCategories.forEach(category => { %>
                        <a href="/?category=<%= encodeURIComponent(category) %>&search=<%= encodeURIComponent(currentSearch || '') %>" class="btn <%= currentCategory === category ? 'btn-primary' : 'btn-outline-primary' %> text-capitalize"><%= category %></a>
                    <% }) %>
                </div>
            <% } %>

            <% if (menu && menu.length > 0) { %>
                <div class="row g-4">
                    <% menu.forEach(item => { 
                        const desc = item.description || '';
                        const words = desc.split(' ');
                    %>
                        <div class="col-md-4 col-lg-3 menu-item" data-category="<%= (item.category || 'Others').toLowerCase().replace(/\s+/g, '-') %>">
                            <div class="card h-100 shadow-sm border-0 menu-card">
                                <img src="<%= item.image || 'https://via.placeholder.com/300x200?text=No+Image' %>" class="card-img-top" alt="<%= item.name %>" style="height: 200px; object-fit: cover;">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title fw-bold"><%= item.name %></h5>
                                        <span class="badge bg-success">₹<%= item.price %></span>
                                    </div>
                                    <p class="card-text text-muted small flex-grow-1">
                                        <% if (words.length > 4) { %>
                                            <span class="short-desc"><%= words.slice(0, 4).join(' ') %>...</span>
                                            <span class="full-desc d-none"><%= desc %></span>
                                            <button type="button" class="btn btn-link p-0 text-decoration-none" style="font-size: inherit;" onclick="toggleDescription(this)">
                                                Read More
                                            </button>
                                        <% } else { %>
                                            <%= desc %>
                                        <% } %>
                                    </p>
                                    
                                    <% if (item.inStock) { %>
                                        <form action="/cart/add" method="POST" class="mt-auto">
                                            <input type="hidden" name="itemId" value="<%= item._id %>">
                                            <div class="input-group mb-2">
                                                <button type="button" class="btn btn-outline-secondary quantity-minus">-</button>
                                                <input type="text" name="quantity" class="form-control text-center" value="1" readonly>
                                                <button type="button" class="btn btn-outline-secondary quantity-plus">+</button>
                                            </div>
                                            <button type="submit" class="btn btn-primary w-100"><i class="fas fa-shopping-cart me-1"></i> Add to Cart</button>
                                        </form>
                                    <% } else { %>
                                        <button class="btn btn-secondary w-100 mt-auto" disabled>Out of Stock</button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center">
                    <p class="text-muted">No menu items found.</p>
                </div>
            <% } %>

            <% if (locals.totalPages && totalPages > 1) { %>
                <% const searchQuery = typeof currentSearch !== 'undefined' && currentSearch ? `search=${encodeURIComponent(currentSearch)}&` : ''; %>
                <% const categoryQuery = currentCategory && currentCategory !== 'all' ? `category=${encodeURIComponent(currentCategory)}&` : ''; %>
                <nav aria-label="Page navigation" class="mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="<%= currentPage === 1 ? '#' : `/?${searchQuery}${categoryQuery}page=${currentPage - 1}` %>">Previous</a>
                        </li>

                        <% 
                        let startPage = Math.max(1, currentPage - 2);
                        let endPage = Math.min(totalPages, currentPage + 2);

                        if (currentPage <= 3) endPage = Math.min(5, totalPages);
                        if (currentPage >= totalPages - 2) startPage = Math.max(1, totalPages - 4);

                        if (startPage > 1) { %>
                            <li class="page-item"><a class="page-link" href="/?<%= searchQuery %><%= categoryQuery %>page=1">1</a></li>
                            <% if (startPage > 2) { %>
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            <% } %>
                        <% } %>

                        <% for(let i = startPage; i <= endPage; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link" href="/?<%= searchQuery %><%= categoryQuery %>page=<%= i %>"><%= i %></a>
                            </li>
                        <% } %>

                        <% if (endPage < totalPages) { %>
                            <% if (endPage < totalPages - 1) { %>
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            <% } %>
                            <li class="page-item"><a class="page-link" href="/?<%= searchQuery %><%= categoryQuery %>page=<%= totalPages %>"><%= totalPages %></a></li>
                        <% } %>

                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="<%= currentPage === totalPages ? '#' : `/?${searchQuery}${categoryQuery}page=${Number(currentPage) + 1}` %>">Next</a>
                        </li>
                    </ul>
                </nav>
            <% } %>
        </div>
    </section>

   
    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container text-center">
            <p class="mb-0">&copy; <%= new Date().getFullYear() %> Canteen Café. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleDescription(btn) {
            const parent = btn.parentElement;
            const shortDesc = parent.querySelector('.short-desc');
            const fullDesc = parent.querySelector('.full-desc');
            
            if (fullDesc.classList.contains('d-none')) {
                fullDesc.classList.remove('d-none');
                shortDesc.classList.add('d-none');
                btn.textContent = 'Read Less';
            } else {
                fullDesc.classList.add('d-none');
                shortDesc.classList.remove('d-none');
                btn.textContent = 'Read More';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Character Suggestion Logic
            const searchInput = document.getElementById('searchInput');
            const suggestionsList = document.getElementById('searchSuggestions');

            if (searchInput) {
                searchInput.addEventListener('input', async (e) => {
                    const query = e.target.value;
                    if (query.length < 1) return;
                    try {
                        const res = await fetch(`/api/search-suggestions?term=${encodeURIComponent(query)}`);
                        const data = await res.json();
                        suggestionsList.innerHTML = data.map(name => `<option value="${name}">`).join('');
                    } catch (err) {
                        console.error('Error fetching suggestions:', err);
                    }
                });
            }

            
            document.querySelectorAll('.quantity-plus').forEach(button => {
                button.addEventListener('click', function() {
                    const input = this.previousElementSibling;
                    input.value = parseInt(input.value) + 1;
                });
            });
    
            document.querySelectorAll('.quantity-minus').forEach(button => {
                button.addEventListener('click', function() {
                    const input = this.nextElementSibling;
                    let value = parseInt(input.value);
                    if (value > 1) {
                        input.value = value - 1;
                    }
                });
            });
        });
    </script>
</body>
</html>