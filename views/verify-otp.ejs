<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP - Campus Canteen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-mug-hot me-2"></i>Canteen Café</a>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <i class="fas fa-envelope-open-text fa-3x text-primary"></i>
                        </div>
                        <h3 class="mb-2">Verify Email</h3>
                        <p class="text-muted small">We've sent a 6-digit code to your email address.</p>
                        
                        <% if (error) { %>
                            <div class="alert alert-danger py-2 small"><%= error %></div>
                        <% } %>
                        
                        <form action="/verify-otp" method="POST">
                            <div class="mb-3">
                                <input type="text" name="otp" class="form-control form-control-lg text-center fw-bold" 
                                       placeholder="000000" maxlength="6" pattern="\d{6}" required autofocus>
                                <div class="form-text mt-2">Enter the 6-digit code</div>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-2">Verify & Register</button>
                        </form>
                        
                        <div class="mt-4 pt-3 border-top">
                            <p class="small text-muted mb-0">
                                Didn't receive the code? <a href="/register" class="text-decoration-none">Try again</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>