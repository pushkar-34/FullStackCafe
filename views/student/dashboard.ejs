<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-mug-hot me-2"></i>Canteen Café</a>
            <div class="ms-auto">
                <div class="d-inline-flex align-items-center bg-white bg-opacity-10 rounded-pill px-3 py-1 border border-secondary me-3">
                    <img src="<%= userProfilePic %>" alt="Profile" class="rounded-circle border border-2 border-white" style="width: 30px; height: 30px; object-fit: cover;">
                    <span class="text-white ms-2 small fw-bold"><%= user.name %></span>
                </div>
                <a href="/" class="btn btn-outline-light btn-sm me-2">Home</a>
                <a href="/logout" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to logout?');">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Welcome<%= user && user.name ? ', ' + user.name : '' %></h2>
            <a href="/" class="btn btn-primary">Browse Menu</a>
        </div>
        <h3>My Orders</h3>
        <% if (orders.length > 0) { %>
            <div class="list-group mt-3">
                <% orders.forEach(order => { %>
                    <div class="list-group-item">
                        <div class="d-flex w-100 justify-content-between">
                            <h5 class="mb-1">Order #<%= order._id %></h5>
                            <small><%= order.createdAt.toDateString() %></small>
                        </div>
                        <p class="mb-1">
                            <% order.items.forEach(item => { %>
                                <span class="badge bg-secondary me-1"><%= item.name %> (x<%= item.quantity || 1 %>)</span>
                            <% }) %>
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fw-bold">Total: ₹<%= order.total %></span>
                            <span class="badge bg-<%= order.status === 'Pending' ? 'warning' : 'success' %>">
                                <%= order.status %>
                            </span>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="alert alert-info mt-3">You haven't placed any orders yet. <a href="/">Order now!</a></div>
        <% } %>
    </div>
</body>
</html>