<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Canteen Café</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-5">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Canteen Café</a>
        </div>
    </nav>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h3 class="text-center mb-4">Reset Password</h3>
                        
                        <% if (error) { %>
                            <div class="alert alert-danger py-2 small"><%= error %></div>
                        <% } %>

                        <form action="/reset-password" method="POST">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Verification OTP</label>
                                <input type="text" name="otp" class="form-control text-center fw-bold" 
                                       placeholder="Enter 6-digit code" maxlength="6" required autofocus>
                            </div>
                            <div class="mb-4">
                                <label class="form-label small fw-bold">New Password</label>
                                <input type="password" name="newPassword" class="form-control" 
                                       placeholder="Enter new password" minlength="6" required>
                                <div class="form-text small">Minimum 6 characters required.</div>
                            </div>
                            <button type="submit" class="btn btn-success w-100 py-2">Update Password</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>