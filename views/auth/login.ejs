<%- include('../partials/header', { title: 'Login' }) %>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="col-md-5">
        <div class="card auth-card p-4">
            <div class="text-center mb-4">
                <h2 class="fw-bold">Welcome Back 👋</h2>
                <p class="text-muted">Login to your Canteen Account</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/login" method="POST">

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" required>
                </div>

                
                <div class="d-grid">
                    <button class="btn btn-custom btn-lg">Login</button>
                </div>

            </form>

            <div class="text-center mt-3">
                <p>Don't have an account?
                    <a href="/signup" class="fw-semibold text-decoration-none">Create Account</a>
                </p>
            </div>

        </div>
    </div>
</div>

<%- include('../partials/footer') %>
