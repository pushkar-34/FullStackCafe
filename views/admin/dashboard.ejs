<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/admin"><i class="fas fa-mug-hot me-2"></i>Canteen Café Admin</a>
            <div class="d-flex align-items-center">
                <div class="d-flex align-items-center bg-white bg-opacity-10 rounded-pill px-3 py-1 border border-secondary me-3">
                    <img src="<%= userProfilePic %>" alt="Profile" class="rounded-circle border border-2 border-white" style="width: 30px; height: 30px; object-fit: cover;">
                    <span class="text-white ms-2 small fw-bold"><%= userName %></span>
                </div>
                <a href="/logout" class="btn btn-outline-light btn-sm" onclick="return confirm('Are you sure you want to logout?');">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h2 class="mb-4">Admin Dashboard</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card text-center h-100 shadow-sm">
                    <div class="card-body">
                        <h3 class="card-title"><i class="fas fa-list-alt text-primary mb-3" style="font-size: 2rem;"></i><br>Orders</h3>
                        <p class="card-text display-6"><%= orderCount %></p>
                        <a href="/admin/orders" class="btn btn-primary w-100">Manage Orders</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center h-100 shadow-sm">
                    <div class="card-body">
                        <h3 class="card-title"><i class="fas fa-users text-success mb-3" style="font-size: 2rem;"></i><br>Users</h3>
                        <p class="card-text display-6"><%= userCount %></p>
                        <a href="/admin/users" class="btn btn-success w-100">Manage Users</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center h-100 shadow-sm">
                    <div class="card-body">
                        <h3 class="card-title"><i class="fas fa-utensils text-warning mb-3" style="font-size: 2rem;"></i><br>Products</h3>
                        <p class="card-text display-6"><%= productCount %></p>
                        <a href="/admin/products" class="btn btn-warning w-100 text-white">Manage Products</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>