<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Kitchen View - Pending Orders</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/admin"><i class="fas fa-fire-burner me-2 text-danger"></i>Kitchen Dashboard</a>
            <div class="d-flex align-items-center">
                <div class="d-flex align-items-center bg-white bg-opacity-10 rounded-pill px-3 py-1 border border-secondary me-3">
                    <img src="<%= userProfilePic %>" alt="Profile" class="rounded-circle border border-2 border-white" style="width: 30px; height: 30px; object-fit: cover;">
                    <span class="text-white ms-2 small fw-bold"><%= userName %></span>
                </div>
                <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/admin" class="text-decoration-none">Admin Dashboard</a></li>
                <li class="breadcrumb-item active">Kitchen View</li>
            </ol>
        </nav>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                    <div class="card-header bg-danger text-white py-3">
                        <h5 class="card-title mb-0 fw-bold"><i class="fas fa-clipboard-list me-2"></i>Preparation Totals</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <% if (Object.keys(kitchenView).length === 0) { %>
                                <li class="list-group-item text-center text-muted py-4">No pending items.</li>
                            <% } %>
                            <% for (const [item, qty] of Object.entries(kitchenView)) { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom">
                                    <span class="fs-5 fw-medium"><%= item %></span>
                                    <span class="badge bg-danger rounded-pill px-3 py-2 fs-6 shadow-sm"><%= qty %></span>
                                </li>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <h3 class="fw-bold mb-4"><i class="fas fa-clock text-warning me-2"></i>Live Order Queue</h3>
                <% if (pendingOrders.length === 0) { %>
                    <div class="alert alert-success py-5 shadow-sm text-center border-0"><i class="fas fa-check-circle fa-2x d-block mb-3"></i>Great job! All orders have been prepared.</div>
                <% } %>
                <% pendingOrders.forEach(order => { %>
                    <div class="card shadow-sm mb-4 border-0">
                        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 fw-bold text-dark">Order #<%= order._id.toString().slice(-6) %> <span class="text-primary mx-2">|</span> <%= order.user.name %></h5>
                            <span class="badge bg-light text-dark border"><%= new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                        </div>
                        <div class="card-body py-4">
                            <ul class="list-group list-group-flush mb-4">
                                <% order.items.forEach(item => { %>
                                    <li class="list-group-item border-0 ps-0 fs-5"><i class="fas fa-circle text-danger me-3" style="font-size: 0.6rem;"></i><strong><%= item.quantity %>x</strong> <%= item.name %></li>
                                <% }); %>
                            </ul>
                            <form action="/admin/order/status" method="POST">
                                <input type="hidden" name="orderId" value="<%= order._id %>">
                                <input type="hidden" name="status" value="Completed">
                                <button type="submit" class="btn btn-success w-100 fw-bold py-3 shadow-sm transition-all"><i class="fas fa-concierge-bell me-2"></i>MARK AS READY & NOTIFY USER</button>
                            </form>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>
</body>
</html>