<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Orders - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/admin"><i class="fas fa-mug-hot me-2"></i>Canteen Café Admin</a>
            <div class="d-flex align-items-center">
                <div class="d-flex align-items-center bg-white bg-opacity-10 rounded-pill px-3 py-1 border border-secondary me-3">
                    <img src="<%= userProfilePic %>" alt="Profile" class="rounded-circle border border-2 border-white" style="width: 30px; height: 30px; object-fit: cover;">
                    <span class="text-white ms-2 small fw-bold"><%= userName %></span>
                </div>
                <a href="/logout" class="btn btn-outline-light btn-sm" onclick="return confirm('Are you sure you want to logout?');">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Manage Orders</h2>
            <a href="/admin" class="btn btn-secondary">Back to Dashboard</a>
        </div>
        
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Order ID</th>
                    <th>User</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                <% orders.forEach(order => { %>
                    <tr>
                        <td><%= order._id %></td>
                        <td><%= order.user ? order.user.name : 'Unknown' %></td>
                        <td>
                            <ul class="list-unstyled mb-0">
                                <% order.items.forEach(item => { %>
                                    <li><%= item.name %> (x<%= item.quantity || 1 %>)</li>
                                <% }) %>
                            </ul>
                        </td>
                        <td>₹<%= order.total %></td>
                        <td>
                            <form action="/admin/order/status" method="POST" class="d-flex align-items-center">
                                <input type="hidden" name="orderId" value="<%= order._id %>">
                                <select name="status" class="form-select form-select-sm me-2" onchange="this.form.submit()">
                                    <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="Completed" <%= order.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                                    <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                                </select>
                            </form>
                        </td>
                        <td><%= order.createdAt.toDateString() %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>