<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Canteen Café</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-5">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-mug-hot me-2"></i>Canteen Café</a>
        </div>
    </nav>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <i class="fas fa-key fa-3x text-warning"></i>
                            <h3 class="mt-3">Forgot Password?</h3>
                            <p class="text-muted small">Enter your email and we'll send you an OTP to reset your password.</p>
                        </div>

                        <% if (error) { %>
                            <div class="alert alert-danger py-2 small"><%= error %></div>
                        <% } %>

                        <form action="/forgot-password" method="POST">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Email Address</label>
                                <input type="email" name="email" class="form-control" placeholder="example@gmail.com" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-2">Send Reset Code</button>
                        </form>
                        <div class="text-center mt-4">
                            <a href="/login" class="text-decoration-none small text-muted">Return to Login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>